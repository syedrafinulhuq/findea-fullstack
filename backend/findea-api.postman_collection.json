{
  "info": {
    "name": "Findea API",
    "description": "Complete Postman collection for the Findea backend API.\n\n**Base URL:** `http://localhost:4000/api`\n\n**Auth:** Set `accessToken` and `refreshToken` variables after login/register. Protected endpoints automatically use the Bearer token.\n\n**Roles:** `CUSTOMER` (default) · `ADMIN` (product creation, all orders)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:4000/api", "type": "string" },
    { "key": "accessToken",  "value": "",                          "type": "string" },
    { "key": "refreshToken", "value": "",                          "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Registration, login, token refresh, and password management.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+8801700000000\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken)  pm.collectionVariables.set('accessToken',  res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken)  pm.collectionVariables.set('accessToken',  res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken)  pm.collectionVariables.set('accessToken',  res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Reset Password (token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"newPassword\": \"NewPassword123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Reset Password (OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password-otp", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password-otp"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile management. All endpoints require a valid Bearer token.",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          },
          "response": []
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+8801800000000\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/me/password", "host": ["{{baseUrl}}"], "path": ["users", "me", "password"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"currentPassword\": \"Password123\",\n  \"newPassword\": \"NewPassword456\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "description": "Product catalogue. Listing and detail endpoints are public. Product creation requires ADMIN role.",
      "item": [
        {
          "name": "List Products",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?search=&category=",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "search",   "value": "",      "description": "Case-insensitive name search" },
                { "key": "category", "value": "",      "description": "Filter by category slug" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/products/categories", "host": ["{{baseUrl}}"], "path": ["products", "categories"] }
          },
          "response": []
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:slug",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":slug"],
              "variable": [{ "key": "slug", "value": "example-product-slug" }]
            }
          },
          "response": []
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Sample Product\",\n  \"slug\": \"sample-product\",\n  \"description\": \"A great product\",\n  \"price\": 499.99,\n  \"stock\": 100,\n  \"imageUrl\": \"https://example.com/image.jpg\",\n  \"categoryId\": \"<category-uuid>\",\n  \"isActive\": true\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Order placement, tracking, and management.",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"customerEmail\": \"customer@example.com\",\n  \"customerName\": \"John Doe\",\n  \"customerPhone\": \"+8801700000000\",\n  \"shippingLine1\": \"123 Main Street\",\n  \"shippingLine2\": \"Apt 4B\",\n  \"shippingCity\": \"Dhaka\",\n  \"shippingState\": \"Dhaka Division\",\n  \"shippingCountry\": \"Bangladesh\",\n  \"items\": [\n    { \"productId\": \"<product-uuid>\", \"quantity\": 2 },\n    { \"productId\": \"<product-uuid-2>\", \"quantity\": 1 }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.orderNumber) pm.collectionVariables.set('orderNumber', res.orderNumber);",
                  "if (res.id) pm.collectionVariables.set('orderId', res.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Track Order",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/track/:orderNumber?email=customer@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "track", ":orderNumber"],
              "variable": [{ "key": "orderNumber", "value": "FID-1234567890" }],
              "query": [{ "key": "email", "value": "customer@example.com", "description": "Optional email to narrow the lookup" }]
            }
          },
          "response": []
        },
        {
          "name": "My Orders",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/orders/mine", "host": ["{{baseUrl}}"], "path": ["orders", "mine"] }
          },
          "response": []
        },
        {
          "name": "All Orders (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
          },
          "response": []
        },
        {
          "name": "Cancel Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/orders/:orderNumber/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":orderNumber", "cancel"],
              "variable": [{ "key": "orderNumber", "value": "FID-1234567890" }]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"reason\": \"Changed my mind\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Flutterwave payment flow: initialize → pay on Flutterwave → verify. Webhook is called by Flutterwave automatically.",
      "item": [
        {
          "name": "Initialize Payment",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payments/initialize", "host": ["{{baseUrl}}"], "path": ["payments", "initialize"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"orderId\": \"<order-uuid>\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.checkoutUrl) console.log('Checkout URL:', res.checkoutUrl);",
                  "if (res.transactionRef) pm.collectionVariables.set('transactionRef', res.transactionRef);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Verify Payment",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payments/verify", "host": ["{{baseUrl}}"], "path": ["payments", "verify"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"transactionId\": \"<flutterwave-transaction-id>\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Flutterwave Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "verif-hash", "value": "<FLUTTERWAVE_WEBHOOK_HASH>", "description": "Must match FLUTTERWAVE_WEBHOOK_HASH env var" }
            ],
            "url": { "raw": "{{baseUrl}}/payments/flutterwave/webhook", "host": ["{{baseUrl}}"], "path": ["payments", "flutterwave", "webhook"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"event\": \"charge.completed\",\n  \"data\": {\n    \"id\": 123456789,\n    \"status\": \"successful\",\n    \"tx_ref\": \"FID-PAY-FID-1234567890-1234567890\",\n    \"amount\": 1080,\n    \"currency\": \"BDT\"\n  }\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Newsletter",
      "description": "Newsletter subscription.",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/newsletter/subscribe", "host": ["{{baseUrl}}"], "path": ["newsletter", "subscribe"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"subscriber@example.com\"\n}"
            }
          },
          "response": []
        }
      ]
    }
  ]
}
